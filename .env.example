# Required — Agora project
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
NEXT_PUBLIC_AGORA_APP_ID=

# Optional — defaults shown
AGORA_CONVERSATIONAL_AI_BASE_URL=https://api.agora.io
AGORA_AGENT_PRESET=deepgram_nova_3,openai_gpt_5_mini,minimax_speech_2_6_turbo
SESSION_IDLE_TIMEOUT_SEC=120
AGENT_SESSION_MAX_MINUTES=30

# Agent personality (server-side only)
AGENT_SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses concise and conversational.
AGENT_GREETING_MESSAGE=Hello! I'm listening. How can I help you today?

# Optional — explicit OpenAI instead of preset LLM only
# OPENAI_API_KEY=
# AGENT_LLM_MODEL=gpt-4o-mini

# n8n tools (disabled by default)
AGORA_ENABLE_TOOLS=false
# N8N_MCP_ENDPOINT=https://your-n8n.example.com/mcp/...
# N8N_MCP_SERVER_NAME=n8n
# N8N_TOOL_WEBHOOK_URL=https://your-n8n.example.com/webhook/tools
# N8N_WEBHOOK_SECRET=
