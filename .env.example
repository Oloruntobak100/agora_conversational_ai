# Required — Agora project (Console → Default Project)
NEXT_PUBLIC_AGORA_APP_ID=

# Required — server-side only (never expose to the browser)
NEXT_AGORA_APP_CERTIFICATE=

# Legacy names still supported by the server if you have not renamed Vercel vars yet:
# AGORA_APP_ID=          (same as NEXT_PUBLIC_AGORA_APP_ID)
# AGORA_APP_CERTIFICATE= (same as NEXT_AGORA_APP_CERTIFICATE)

# Must match agentUid in app/api/invite-agent/route.ts (lib/env.ts)
NEXT_PUBLIC_AGENT_UID=123456

# Optional opening line
NEXT_AGENT_GREETING=Hello! I'm listening. How can I help you today?

# Optional BYOK — uncomment matching blocks in app/api/invite-agent/route.ts
# NEXT_DEEPGRAM_API_KEY=
# NEXT_LLM_URL=https://api.openai.com/v1/chat/completions
# NEXT_LLM_API_KEY=
# NEXT_ELEVENLABS_API_KEY=
# NEXT_ELEVENLABS_VOICE_ID=

# Optional n8n tool bridge (not wired in invite-agent until MCP is enabled)
# N8N_TOOL_WEBHOOK_URL=
# N8N_WEBHOOK_SECRET=
